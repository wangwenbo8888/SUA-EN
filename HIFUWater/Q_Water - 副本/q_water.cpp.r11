void Q_Water::getwater()
{
    getTemp();
    getTemp2();
    getLevel();
    getMeter();
    getVacuum();
}

void Q_Water::getTemp()
{
//    QByteArray baSend;
//    baSend[0]=0x15;
//    baSend[1]=0x03;
//    baSend[2]=0x00;
//    baSend[3]=0x00;
//    baSend[4]=0x00;
//    baSend[5]=0x01;
//    baSend[6]=0x87;
//    baSend[7]=0x1E;
//    m_serial->clear();
//    m_serial->write(baSend);
//    m_serial->waitForBytesWritten(50);
//    int num = receiveSerial_Status(7);
//    if(num!=7||chRead[0]!=PUMP_TEMP)
//    {
//        qDebug()<<"Get Temp data Error";
//    }
//    else
//    {
//        m_Temp=chRead[3]*256+chRead[4];
//        emit TempUpdate(m_Temp);
//    }
    b_Disable_Slot=true;
    chSend[0]=COM_GET_TEMP;      //get meter
    sendSerial(2);
    int num = receiveSerial(4);
    b_Disable_Slot=false;
    if(num!=4 || chRead[0] != COM_GET_TEMP) {qDebug()<<"Get Temp data Error";}
    else{
        qDebug()<<"temp======"<<m_Temp;
        m_Temp=chRead[1]*256+chRead[2];
        emit TempUpdate(m_Temp);
    }
}

void Q_Water::getTemp2()
{
    b_Disable_Slot=true;
    chSend[0]=COM_GET_TEMP_2;      //get meter
    sendSerial(2);
    int num = receiveSerial(4);
    b_Disable_Slot=false;
    if(num!=4 || chRead[0] != COM_GET_TEMP_2) {qDebug()<<"Get Temp2 data Error";}
    else{
        qDebug()<<"temp2======"<<m_Temp2;
        m_Temp2=chRead[1]*256+chRead[2];
        emit Temp2Update(m_Temp2);
    }
}

void Q_Water::getMeter()
{
    b_Disable_Slot=true;
    chSend[0]=COM_GET_METER;      //get meter
    sendSerial(2);
    int num = receiveSerial(4);
    b_Disable_Slot=false;
    if(num!=4 || chRead[0] != COM_GET_METER) {qDebug()<<"Get Meter data Error";}
    else{
        m_RecMeter=chRead[1]*256+chRead[2];
        emit MeterUpdate(m_RecMeter);
        meterAutoMode();
    }
}

void Q_Water::getVacuum()
{
    b_Disable_Slot=true;
    chSend[0]=COM_GET_Vacuum;      //get meter
    sendSerial(2);
    int num = receiveSerial(4);
    b_Disable_Slot=false;
    if(num!=4 || chRead[0] != COM_GET_Vacuum) {qDebug()<<"Get Vacuum data Error";}
    else{
        m_Vacuum=chRead[1]*256+chRead[2];
//        Vacuum=((float)m_Vacuum/100);
        emit VacuumUpdate(m_Vacuum);
    }
}

void Q_Water::getLevel()
{
    b_Disable_Slot=true;
    chSend[0]=COM_GET_LEVEL;      //get meter
