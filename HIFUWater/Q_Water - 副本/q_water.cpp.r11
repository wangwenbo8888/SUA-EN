    if(num!=4 || chRead[0] != COM_GET_LEVEL) {qDebug()<<"Get Level data Error";}
    else{
        m_Level=chRead[1]*256+chRead[2];
        emit LevelUpdate(m_Level);
    }
}

void Q_Water::queryTemp(bool enable)
{
    if(enable&&Port_Status)
    {
        tempTimer.start();
    }
    else
    {
        tempTimer.stop();
    }
}

void Q_Water::queryMeter(bool enable)
{
    if(enable&&Port_Status)
        meterTimer.start();
    else
        meterTimer.stop();
}

void Q_Water::queryLevel(bool enable)
{
    if(enable&&Port_Status)
        levelTimer.start();
    else
        levelTimer.stop();
}

void Q_Water::queryVacuum(bool enable)
{
    if(enable&&Port_Status)
        vacuumTimer.start();
    else
        vacuumTimer.stop();
}

void Q_Water::openAutoMode()
{
    waterAutoOpen = true;
    setduPump1(AutoSpeedIN);
    setduPump2(AutoSpeedOUT);
//    OpenXHPump();
    OpenZKPump();
    connect(this,SIGNAL(signalAdjPumpOut()),this,SLOT(slotAdjPumpOut()));
    m_SpdOut_Set = AutoSpeedOUT;
}

void Q_Water::closeAutoMode()
{
    waterAutoOpen = false;
    closeduPump1();
    closeduPump2();
//    CloseXHPump();
    CloseZKPump();
    disconnect(this,SIGNAL(signalAdjPumpOut()),this,SLOT(slotAdjPumpOut()));
}

void Q_Water::setMeter(int meter)
{
    m_PreMeter = meter;
}

void Q_Water::meterAutoMode()
{
    if(waterAutoOpen)
    {
        int dlt = m_RecMeter-m_PreMeter;
        bool b_chg = false;
        switch(m_SpdOut_Adj)
        {
        case 20:
            if (dlt<=5){
                m_SpdOut_Adj=5;
                b_chg=true;
            }
            break;
        case -20:
            if (dlt>=-5){
                m_SpdOut_Adj=-5;
                b_chg=true;
            }
            break;
        case 5:
            if (dlt>10){
                m_SpdOut_Adj=20;
                b_chg=true;
            }else if (dlt<=0){
                m_SpdOut_Adj=0;
                b_chg=true;
            }
            break;
        case -5:
            if (dlt<-10){
                m_SpdOut_Adj=-20;
                b_chg=true;
            }else if (dlt>=0){
                m_SpdOut_Adj=0;
                b_chg=true;
            }
            break;
        case 0:
            if (dlt>5){
                m_SpdOut_Adj=5;
                b_chg=true;
            }else if (dlt<-5){
                m_SpdOut_Adj=-5;
                b_chg=true;
            }
            break;
        default:
            m_SpdOut_Adj=0;
            break;
        }
        if(b_chg)
            emit signalAdjPumpOut();
    }
}

void Q_Water::slotAdjPumpOut()
{
    setduPump2(m_SpdOut_Set+m_SpdOut_Adj);
    emit SpeedOutUpdate(m_SpdOut_Set+m_SpdOut_Adj);
}

int Q_Water::receiveSerial_Status(int num)
{
    int n=0;
    QByteArray baRead;
    if (num==0) num=255;
    if(!(m_serial->waitForReadyRead(100))){qDebug()<<"TimeOut Error";return -1;}

    n=m_serial->bytesAvailable();
    baRead=m_serial->readAll();
    while (n<num) {
        if(!(m_serial->waitForReadyRead(100))) break;
        n+=m_serial->bytesAvailable();
        baRead+=m_serial->readAll();
    }
//    qDebug()<<"传感器接收消息："<<baRead.toHex();
//    qDebug()<<"baRead:"<<baRead.toHex();
    for(int i=0;i<n;i++){
       chRead[i]=baRead[i];
    }
    if (num==255) num=n;
    if (CRC16(&chRead[0],num) == 0) return num;
    else{
        return -2;
    }
}

void Q_Water::Delay_MSec(unsigned int msec)
{
    QTime _Timer = QTime::currentTime().addMSecs(msec);
    while(QTime::currentTime() < _Timer)
        QCoreApplication::processEvents(QEventLoop::AllEvents,100);
}

void Q_Water::UpdateAuto(bool isauto)
{
    if(isauto)
    {
        qDebug()<<"1111111111111";
        b_Disable_Slot=true;
        chSend[0]=COM_AUTOMODE;
        chSend[1]=1;
        sendSerial(3);
        int num = receiveSerial(2);
        b_Disable_Slot=false;
        if(num!=2 || chRead[0] != COM_DONE) {qDebug()<<"Set auto data Error";}
    }
    else
    {
        qDebug()<<"2222222222222";
        b_Disable_Slot=true;
        chSend[0]=COM_AUTOMODE;
        chSend[1]=0;
        sendSerial(3);
        int num = receiveSerial(2);
        b_Disable_Slot=false;
        if(num!=2 || chRead[0] != COM_DONE) {qDebug()<<"Set auto data Error";}
    }
}

void Q_Water::ReadData()
{
    if(b_Disable_Slot) return;
    int n=0;
    QByteArray baRead;
//    if(!(m_serial->waitForReadyRead(100))){qDebug()<<"TimeOut Error";}

    n=m_serial->bytesAvailable();
    qDebug()<<"传感器接收数量："<<n;
    baRead=m_serial->readAll();
//    while (n<3) {
//        if(!(m_serial->waitForReadyRead(100))) break;
//        n+=m_serial->bytesAvailable();
//        baRead+=m_serial->readAll();
//    }
    qDebug()<<"传感器接收消息："<<baRead.toHex();
    if(baRead.at(0)==COM_BED_KEY)
    {
        switch(baRead[1])
        {
            case BED_COM1:
//                 OpenWaterOut();
                 break;
            case BED_COM2:
                 break;
            case BED_COM3:
                 break;
            case BED_COM4:
                 break;
            case BED_COM5:
                 break;
            case BED_COM6:
                 break;
            case BED_OFF:
//                 CloseWaterOut();
                 break;
        }
    }
    else if(baRead.at(0)==COM_ELE_KEY)
    {
        switch(baRead.at(1))
        {
            case ELE_COM1:
                if(baRead.at(2)==0x00)
                {
                    emit PosZ_control(0);
                    break;
                }
                else if(baRead.at(2)==0x01)
                {
                    emit PosZ_control(-1);
                    break;
                }
            case ELE_COM2:
                if(baRead.at(2)==0x00)
                {
                    emit PosZ_control(0);
                    break;
                }
                else if(baRead.at(2)==0x01)
                {
                    emit PosZ_control(1);
                    break;
                }
            case ELE_COM3:
                if(baRead.at(2)==0x00)
                {
                    emit PosL_control(0);
                    break;
                }
                else if(baRead.at(2)==0x01)
                {
                    emit PosL_control(-1);
                    break;
                }
            case ELE_COM4:
                if(baRead.at(2)==0x00)
                {
                    emit PosL_control(0);
                    break;
                }
                else if(baRead.at(2)==0x01)
                {
                    emit PosL_control(1);
                    break;
                }
            case ELE_COM5:
                if(baRead.at(2)==0x00)
                {
                    emit PosF_control(0);
                    break;
                }
                else if(baRead.at(2)==0x01)
                {
                    emit PosF_control(-1);
                    break;
                }
            case ELE_COM6:
                if(baRead.at(2)==0x00)
                {
                    emit PosF_control(0);
                    break;
                }
                else if(baRead.at(2)==0x01)
                {
                    emit PosF_control(1);
                    break;
                }

        }
    }
}
//    qDebug()<<"baRead:"<<baRead.toHex();
//    for(int i=0;i<n;i++){
//       chRead[i]=baRead[i];
//    }
//    if (caluCRC(&chRead[0],4) == 0)
//    {
//        switch(chRead[0])
//        {
//            case COM_GET_METER :
//                m_RecMeter=chRead[1]*256+chRead[2];
//                emit MeterUpdate(m_RecMeter);
